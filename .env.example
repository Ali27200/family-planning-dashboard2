# Vercel KV (Redis) - التخزين الدائم الموصى به
# يتم إضافتها تلقائياً عند ربط KV بالمشروع في Vercel Dashboard
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# JSONBin.io - بديل إذا ما استخدمت Vercel KV
# سجل في https://jsonbin.io واحصل على API Key و Bin ID
JSONBIN_API_KEY=""
JSONBIN_BIN_ID=""

# PORT: The port the server runs on (default: 3000)
PORT=3000

# HOST: The host address to bind to (default: 0.0.0.0 — all interfaces)
# Set to 0.0.0.0 to allow access from other devices on the network
HOST=0.0.0.0
